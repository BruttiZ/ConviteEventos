{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "invitely",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:laravel": "vite build",
        "build:vercel": "vite build --config vite.vercel.config.js",
        "dev": "vite",
        "format": "prettier --ignore-unknown --write \"resources/**/*.{css,js,jsx,ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"vercel-public/**/*\" \"*.{js,json,md}\" \"docs/**/*.md\"",
        "format:check": "prettier --ignore-unknown --check \"resources/**/*.{css,js,jsx,ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"vercel-public/**/*\" \"*.{js,json,md}\" \"docs/**/*.md\"",
        "lint": "eslint \"resources/js/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" --max-warnings=0",
        "lint:fix": "eslint \"resources/js/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" --fix",
        "prepare": "husky",
        "typecheck": "tsc --noEmit"
    },
    "lint-staged": {
        "resources/**/*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "lib/**/*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": [
            "prettier --write"
        ],
        "docs/**/*.md": [
            "prettier --write"
        ],
        "*.php": [
            "vendor/bin/pint"
        ]
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.1",
        "@radix-ui/react-slot": "^1.2.3",
        "@supabase/supabase-js": "^2.108.0",
        "@tanstack/react-query": "^5.85.5",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "framer-motion": "^12.23.12",
        "lucide-react": "^0.468.0",
        "qrcode.react": "^4.2.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-hook-form": "^7.62.0",
        "react-router-dom": "^7.8.2",
        "tailwind-merge": "^3.3.1",
        "zod": "^4.1.5"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.0.0",
        "@types/react": "^19.0.8",
        "@types/react-dom": "^19.0.3",
        "@vitejs/plugin-react": "^4.3.4",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^10.4.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "husky": "^9.1.7",
        "laravel-vite-plugin": "^2.0.0",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.60.0",
        "vite": "^7.0.7"
    }
}
